# 基础镜像。默认使用 ECR Public 的 Docker 官方 Python 镜像副本，避免部分网络下 Docker Hub 认证失败。
PYTHON_IMAGE=public.ecr.aws/docker/library/python:3.12-slim

# 外部线路条数。多 WAN 按“新建连接数”分流时，用它控制总连接分组。
LINE_COUNT=2

# 每条线路创建几个下载连接。默认 4，通常比 1 更容易跑满速度。
CONNECTIONS_PER_LINE=4

# 是否启用总限速。
RATE_LIMIT_ENABLED=false

# 总限速，单位 Mbps。启用限速时，会平均分配到所有下载连接。
RATE_LIMIT_MBPS=100

# 每天运行时间。START_TIME 和 END_TIME 相同表示全天运行。
TZ=Asia/Shanghai
START_TIME=00:00
END_TIME=00:00

# 默认自动选择中国境内 Speedtest 服务器。
AUTO_SELECT_SPEEDTEST=true
SPEEDTEST_COUNTRY=CN
SPEEDTEST_SEARCH=China
SPEEDTEST_SERVER_LIMIT=20
SPEEDTEST_DOWNLOAD_SIZE=4000
SPEEDTEST_REFRESH_SECONDS=3600
PUBLIC_IP_URL=https://api64.ipify.org

# 手动备用下载地址，多个地址用英文逗号分隔。留空表示自动选服失败后等待重试。
DOWNLOAD_URLS=

# 可选高级参数。
CHUNK_SIZE=262144
REQUEST_TIMEOUT_SECONDS=30
SCHEDULE_POLL_SECONDS=30
STATS_INTERVAL_SECONDS=60
LOG_LEVEL=INFO

# 可选：让容器在局域网里拿一个独立 IP，路由器会把它看成独立设备。
# 启用时请使用 docker-compose.macvlan.yml，或者运行部署脚本并选择“独立局域网 IP”。
USE_MACVLAN=false
LAN_PARENT_INTERFACE=eth0
LAN_SUBNET_CIDR=192.168.1.0/24
LAN_GATEWAY=192.168.1.1
CONTAINER_IPV4_ADDRESS=192.168.1.250
